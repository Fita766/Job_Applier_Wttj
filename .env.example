# 🤖 WTTJ Bot (v2.2) - Configuration

# --- CLÉS API ---
# Requis pour l'analyse d'offres et la personnalisation de CV
MISTRAL_API_KEY=votre_cle_mistral
MISTRAL_MODEL=mistral-large-latest

OPENAI_API_KEY=votre_cle_openai
OPENAI_MODEL=gpt-4o

# --- SÉLECTION IA ---
# Modèle utilisé par défaut au lancement via CLI (mistral ou openai)
PRIMARY_LLM=mistral

# --- CRÉDENTIELS PLATEFORMES ---

# Welcome to the Jungle
WTTJ_EMAIL=votre@email.com
WTTJ_PASSWORD=votre_password
# true = le bot s'arrête pour vous laisser vous connecter manuellement
WTTJ_MANUAL_LOGIN=false

# Hellowork / Glassdoor / VIE
# (La connexion est principalement manuelle pour la sécurité, activez SHOW_BROWSER=true)

# --- INFOS CANDIDAT (Remplir impérativement) ---
PRENOM=Jean
NOM=Dupont
EMAIL=jean.dupont@email.com
TELEPHONE=0601020304
LINKEDIN=https://linkedin.com/in/jeandupont
ADRESSE=Paris, France

# --- CONFIGURATION DU CV ---
# Mode par défaut au lancement CLI
# 'direct' -> PDF original (CV_PATH)
# 'pptx'   -> Modification IA d'un master template PowerPoint
# 'html'   -> Génération IA d'un CV en HTML converti en PDF
CV_MODE=direct
DISPONIBILITE=Disponible immediatement pour tout entretien, aux horaires qui vous conviennent.
TYPE_CONTRAT=CDI
CV_CONTEXT_HINTS=Entreprises exactes: XXX XXX XXX
# Chemins des fichiers sources
CV_PATH=./cv_statique_original.pdf
CV_PATH_PPTX=./template_cv_master.pptx

# --- PARAMÈTRES DU BOT ---
# Nombre max d'offres à traiter par session
MAX_OFFRES=10
# Nombre de pages à scanner dans les résultats de recherche
MAX_PAGES=3
# Délai entre deux candidatures pour éviter d'être banni (en secondes)
DELAI_ENTRE_CANDIDATURES=10
# Voir le navigateur en action (true/false)
SHOW_BROWSER=true

# --- OPTIONS AVANCÉES ---
# Limites de puces par bloc pour le mode PPTX (format JSON)
CV_BULLET_LIMITS={"Expérience 1": 5, "Expérience 2" : 4}
# Dossier de sortie pour les CV générés
OUTPUT_DIR=cv_genere
